# ── Telegram ──────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# Telegram chat id(s) allowed to command the bot (comma-separated).
# Leave empty on first run — message the bot and it replies with your chat_id.
ALLOWED_CHAT_IDS=

# ── Scope ─────────────────────────────────────────────────
# Working directory the bot operates in (and the root for /remote repo lookup)
WORKDIR=~/Developer
DEV_ROOT=~/Developer

# ── Claude ────────────────────────────────────────────────
# Path to the real claude binary (not a shell alias)
CLAUDE_BIN=~/.local/bin/claude
# Headless permission mode: acceptEdits | auto | bypassPermissions | default | plan
PERMISSION_MODE=acceptEdits
# /remote (remote-control) permission mode: acceptEdits | auto | bypassPermissions
REMOTE_PERMISSION_MODE=acceptEdits
# Per-task timeout (seconds)
TIMEOUT_SEC=1800

# ── Optional ──────────────────────────────────────────────
# LaunchAgent label (menu bar app uses this to manage the bot)
# BOT_LABEL=com.claude.remotebot
# TMUX_BIN=/opt/homebrew/bin/tmux
# PATH_PREFIX=/opt/homebrew/bin:/opt/homebrew/opt/node@20/bin:/opt/homebrew/opt/libpq/bin
